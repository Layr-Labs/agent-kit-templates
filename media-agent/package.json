{
  "name": "media-agent",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run site:build && bun --watch src/main.ts",
    "start": "bun run site:build && bun src/main.ts",
    "build": "bun run site:build && tsc",
    "typecheck": "tsc --noEmit && tsc --noEmit -p site/tsconfig.json",
    "test": "bun run site:build && bun test",
    "site:dev": "vite --config site/vite.config.ts",
    "site:build": "vite build --config site/vite.config.ts",
    "site:preview": "vite preview --config site/vite.config.ts",
    "test:live-skill-upgrade": "bun run scripts/live-skill-upgrade-smoke.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.53",
    "@aws-sdk/client-s3": "^3.993.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@layr-labs/ai-gateway-provider": "^1.0.0",
    "@layr-labs/ecloud-sdk": "0.4.0",
    "@solana/web3.js": "^1.98.4",
    "ai": "^6.0.111",
    "bip39": "^3.1.0",
    "browser-autopilot": "^0.5.7",
    "ed25519-hd-key": "^1.3.0",
    "eigenmail-sdk": "^0.1.1",
    "fastify": "^5.3.0",
    "pg": "^8.18.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "replicate": "^1.4.0",
    "smol-toml": "^1.3.1",
    "substack-skill": "^0.1.5",
    "twitter-api-v2": "^1.19.0",
    "viem": "^2.45.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "typescript": "^5.7.0",
    "vite": "^7.1.10"
  }
}
