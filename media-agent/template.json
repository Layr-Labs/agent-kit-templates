{
  "id": "media-agent",
  "name": "Media Agent",
  "description": "Autonomous media entity that publishes to Twitter and Substack",
  "dockerfile": "Dockerfile",
  "imageTag": "agentkit-media-agent:latest",
  "files": [
    { "name": "SOUL.md", "envKey": "SOUL_MD_B64", "required": true, "consentRequired": false },
    { "name": "PROCESS.toml", "envKey": "PROCESS_TOML_B64", "required": true, "consentRequired": false },
    { "name": "constitution.md", "envKey": "CONSTITUTION_MD_B64", "required": true, "consentRequired": true }
  ],
  "platforms": [
    {
      "id": "twitter",
      "label": "Twitter/X",
      "description": "Visual posts, threads, engagement",
      "envVars": [
        { "key": "TWITTER_EMAIL", "label": "Twitter email", "required": true },
        { "key": "TWITTER_USER", "label": "Twitter username (without @)", "required": true },
        { "key": "TWITTER_PASS", "label": "Twitter password", "required": true, "secret": true },
        { "key": "TWITTER_TOTP_KEY", "label": "2FA TOTP secret", "required": false, "secret": true }
      ],
      "autoVars": { "TWITTER_POSTING_ENABLED": "true", "TWITTER_USERNAME": "$TWITTER_USER" }
    },
    {
      "id": "substack",
      "label": "Substack",
      "description": "Newsletters, long-form articles",
      "envVars": [],
      "note": "Substack agents self-provision — no credentials needed."
    }
  ],
  "skillsCatalog": [
    {
      "id": "arxiv-reader",
      "name": "ArXiv Paper Reader",
      "description": "Search and read full papers from ArXiv (HTML + abstract fallback)",
      "tools": ["search_arxiv", "get_paper_metadata", "read_paper"],
      "pipelineIntegration": { "scanner": ["search_arxiv", "get_paper_metadata", "read_paper"] }
    }
  ],
  "configurePrompt": "configure-prompt.md",
  "nameParser": {
    "file": "SOUL.md",
    "pattern": "^##\\s+Name\\s*\\n+(.+)"
  }
}
