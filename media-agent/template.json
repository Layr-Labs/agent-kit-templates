{
  "id": "media-agent",
  "name": "Media Agent",
  "description": "Sovereign media entity that publishes to Twitter and Substack",
  "dockerfile": "Dockerfile",
  "caddyfile": "Caddyfile",
  "imageTag": "agentkit-media-agent:latest",
  "files": [
    { "name": "SOUL.md", "envKey": "SOUL_MD_B64", "required": true, "consentRequired": false },
    { "name": "PROCESS.toml", "envKey": "PROCESS_TOML_B64", "required": true, "consentRequired": false },
    { "name": "constitution.md", "envKey": "CONSTITUTION_MD_B64", "required": true, "consentRequired": true }
  ],
  "platforms": [
    {
      "id": "twitter",
      "label": "Twitter/X",
      "description": "Visual posts, threads, engagement",
      "envVars": [
        { "key": "TWITTER_USERNAME", "label": "Twitter username (without @)", "required": true },
        { "key": "TWITTER_BEARER_TOKEN", "label": "Bearer Token", "required": true, "secret": true },
        { "key": "TWITTER_API_KEY", "label": "API Key (Consumer Key)", "required": true, "secret": true },
        { "key": "TWITTER_API_SECRET", "label": "API Key Secret (Consumer Secret)", "required": true, "secret": true },
        { "key": "TWITTER_ACCESS_TOKEN", "label": "Access Token", "required": true, "secret": true },
        { "key": "TWITTER_ACCESS_SECRET", "label": "Access Token Secret", "required": true, "secret": true }
      ],
      "autoVars": { "TWITTER_POSTING_ENABLED": "true" }
    },
    {
      "id": "substack",
      "label": "Substack",
      "description": "Newsletters, long-form articles",
      "envVars": [],
      "note": "Substack agents self-provision — no credentials needed."
    }
  ],
  "skillsCatalog": [
    {
      "id": "arxiv-reader",
      "name": "ArXiv Paper Reader",
      "description": "Search and read full papers from ArXiv (HTML + abstract fallback)",
      "tools": ["search_arxiv", "get_paper_metadata", "read_paper"],
      "pipelineIntegration": { "scanner": ["search_arxiv", "get_paper_metadata", "read_paper"] }
    }
  ],
  "configurePrompt": "configure-prompt.md",
  "nameParser": {
    "file": "SOUL.md",
    "pattern": "^##\\s+Name\\s*\\n+(.+)"
  }
}
