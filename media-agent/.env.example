# Agent identity — mnemonic derives wallet addresses AND email (via EigenMail)
MNEMONIC=

ANTHROPIC_API_KEY=
AI_GATEWAY_API_KEY=
TEST_MODE=false
PORT=3000

# Platform: "twitter" or "substack"
PLATFORM=twitter

# Twitter (required when PLATFORM=twitter)
TWITTER_POSTING_ENABLED=false
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_USERNAME=

# Substack (required when PLATFORM=substack)
SUBSTACK_HANDLE=
RSS_FEEDS=

# Video pipeline — optional, enables Replicate Veo 3.1
REPLICATE_API_TOKEN=

# Postgres backup — optional, encrypted state backup
DATABASE_URL=

# Narrator (voice) — optional, enables ElevenLabs TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Cloudflare R2 CDN — optional, enables edge-cached media
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
